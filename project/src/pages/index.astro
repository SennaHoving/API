			<link rel="icon" href="/favicon.ico" />
			<meta name="viewport" content="width=device-width" />
			<meta name="generator" content={Astro.generator} />
			<title>API</title>

			<link rel="stylesheet" href="/src/styles/main.css">
		</head>
		<body>
			<header>
				<h1>Workout tracker</h1>
			</header>
			<div>
				<!-- <p>Sup {exercises[1].muscles}</p>
				<p>Dit nummer: {exercises[1].muscles} is deze muscle: {muscles.find(m => m.id === exercises[1].muscles[0]).name}</p> -->

				<!-- <p>Exercise geselecteerd: {exercises[1].id}</p>
				<p>Translated to: {exerci	seTrans.find(x => x.exercise === exercises[1].id)?.name}</p> -->
				<!-- <p>Corresponing muscle: {muscles.find(x => x.id === exercises[1].id).name}</p> -->

				<h2>Exercise Library</h2>
				<div> 
					<ul class="field">
						{exerciseTranslate.map((exercise) => (
