	---
	const [ExerciseRes, MusclesRes, ExerciseTranslateRes] = await Promise.all([
		fetch("https://wger.de/api/v2/exercise/?limit=100"), 
		fetch("https://wger.de/api/v2/muscle/?limit=100"), 
		fetch("https://wger.de/api/v2/exercise-translation/?limit=100")
	]);

	const exercisesData = await ExerciseRes.json();
	const exercises = exercisesData.results;

	const muscleData = await MusclesRes.json(); 
	const muscles = muscleData.results;

	const exerciseTransData = await ExerciseTranslateRes.json(); 
	const exerciseTranslate = exerciseTransData.results;
